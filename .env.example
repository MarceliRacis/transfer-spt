# Spotify
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=http://localhost:3000/auth/callback

# Session
SESSION_SECRET=change-this-to-a-random-string

# Redis Cloud (format: redis://default:PASSWORD@HOST:PORT)
REDIS_URL=redis://default:yourpassword@redis-12345.c1.eu-west-1-2.ec2.cloud.redislabs.com:12345

# Server
PORT=3000
NODE_ENV=development

# Dev only — where Vite runs (backend redirects here after OAuth)
FRONTEND_DEV_URL=http://localhost:5173

# Security / CSP (Optional - semicolon-separated list of hosts allowed to embed the app in an iframe)
# e.g. IFRAME_URL=*.racis.dev;github.com
IFRAME_URL=
